def status_badge(status: str) -> str:
    styles = {
        "new": ("Новый", "bg-amber-100 text-amber-800 border-amber-200"),
        "active": ("В работе", "bg-teal-100 text-teal-800 border-teal-200"),
        "completed": ("Завершен", "bg-blue-100 text-blue-800 border-blue-200"),
        "archived": ("Архив", "bg-slate-100 text-slate-700 border-slate-200"),
    }
    label, cls = styles.get(status, (html_escape(status), "bg-slate-100 text-slate-700 border-slate-200"))
    return f'<span class="px-3 py-1 rounded-full text-xs font-semibold border {cls}">{label}</span>'


def option(value: str, label: str, selected: str) -> str:
    sel = "selected" if value == selected else ""
    return f'<option value="{value}" {sel}>{label}</option>'


def select_option(value: str, label: str, selected: str) -> str:
    sel = "selected" if value == selected else ""
    return f'<option value="{value}" {sel}>{label}</option>'


def test_card(tag: str, title: str, text: str) -> str:
    return f"""
    <div class="border border-slate-200 rounded-xl p-4 bg-slate-50">
        <div class="text-xs font-bold text-slate-500">{tag}</div>
        <div class="text-sm font-bold text-slate-900 mt-1">{title}</div>
        <div class="text-sm text-slate-700 mt-2">{text}</div>
    </div>
    """


def html_escape(s: str) -> str:
    return (
        s.replace("&", "&amp;")
        .replace("<", "&lt;")
        .replace(">", "&gt;")
        .replace('"', "&quot;")
        .replace("'", "&#x27;")
    )


