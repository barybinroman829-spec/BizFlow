def header_title(active_nav: str, authed: bool) -> str:
    if not authed:
        return "Добро пожаловать в BizFlow"
    titles = {"dashboard": "Обзор системы", "clients": "База клиентов", "docs": "Документация"}
    return titles.get(active_nav, "BizFlow")


def nav_button(key: str, label: str, icon: str, active_nav: str, href: Optional[str] = None) -> str:
    active = key == active_nav
    cls = (
        "bg-emerald-50 text-primary border-emerald-100"
        if active
        else "text-slate-600 hover:bg-slate-50 hover:text-slate-900 border-transparent"
    )
    if href is None:
        href = url_for(key)
    return f"""
    <a href="{href}"
    class="w-full flex items-center gap-3 px-4 py-3 rounded-lg text-sm font-medium transition-all duration-200 border {cls}">
        <i class="fas {icon} w-5"></i> {label}
    </a>
    """


def flash_block() -> str:
    return """
    {% with messages = get_flashed_messages(with_categories=true) %}
    {% if messages %}
    <div class="space-y-3 mb-6">
        {% for category, message in messages %}
        {% if category == 'success' %}
        <div class="bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-lg text-sm flex gap-2 items-start">
            <i class="fas fa-check-circle mt-0.5"></i><div><b>Успех.</b> {{ message }}</div>
        </div>
        {% else %}
        <div class="bg-rose-50 border border-rose-200 text-rose-800 px-4 py-3 rounded-lg text-sm flex gap-2 items-start">
            <i class="fas fa-exclamation-circle mt-0.5"></i><div><b>Ошибка.</b> {{ message }}</div>
        </div>
        {% endif %}
        {% endfor %}
    </div>
    {% endif %}
    {% endwith %}
    """


